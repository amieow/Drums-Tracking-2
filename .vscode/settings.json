{
  // DaaS RAD Platform Settings
  
  // ===== GitHub Copilot =====
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "chat.instructionsFilesLocations": [
    ".github/instructions"
  ],
  "chat.promptFilesLocations": [
    ".github/prompts"
  ],
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": false,
  
  // ===== Copilot Customization =====
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "text": "Use conventional commit format: type(scope): description" },
    { "text": "Types: feat, fix, docs, style, refactor, test, chore" },
    { "text": "Keep the first line under 72 characters" },
    { "text": "Reference issue numbers when applicable: closes #123" }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    { "file": ".github/instructions/api-routes.instructions.md" },
    { "file": ".github/instructions/react-components.instructions.md" }
  ],
  
  // ===== DaaS Configuration =====
  "daas.mcpToken": "",  // Set your MCP token here
  
  // ===== Editor Settings =====
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  
  // ===== TypeScript =====
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  
  // ===== Files =====
  "files.associations": {
    "*.instructions.md": "markdown",
    "*.prompt.md": "markdown",
    "*.agent.md": "markdown"
  },
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/.git": true
  },
  
  // ===== Search =====
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/pnpm-lock.yaml": true
  },
  
  // ===== Testing =====
  "vitest.enable": true,
  "vitest.commandLine": "pnpm vitest"
}
