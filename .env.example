# =============================================================================
# Drums Tracking — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development and fill in the values.
# Never commit .env.local or any file containing real secrets to version control.
#
# For AWS Amplify deployments, set these variables in the Amplify Console
# (App settings → Environment variables). The amplify.yml build phase will
# echo server-side variables into .env.production so they are available to
# Next.js API routes at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Public (safe to expose to the browser)
# -----------------------------------------------------------------------------

# The base URL of your Supabase project.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.db3.buildpad.ai

# The anon/public key for your Supabase project.
# Safe to expose client-side; enforces Row Level Security policies.
# Found in: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# -----------------------------------------------------------------------------
# Supabase — Server-side only (NEVER expose to the browser)
# -----------------------------------------------------------------------------

# The service role key for your Supabase project.
# Bypasses Row Level Security — keep this secret and server-side only.
# Found in: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# -----------------------------------------------------------------------------
# Buildpad DaaS — Backend API
# -----------------------------------------------------------------------------

# Base HTTP URL for the Buildpad DaaS REST API backend.
# Used by Next.js API routes to forward validated requests to the DaaS layer.
# Example: https://<project-id>.daas3.buildpad.ai
DAAS_BASE_URL=https://<your-project-id>.daas3.buildpad.ai

# WebSocket URL for the Buildpad DaaS real-time broadcaster.
# Used by the WebSocket client to subscribe to item_updated / item_created events.
# Example: wss://<project-id>.daas3.buildpad.ai/ws
DAAS_WS_URL=wss://<your-project-id>.daas3.buildpad.ai/ws
